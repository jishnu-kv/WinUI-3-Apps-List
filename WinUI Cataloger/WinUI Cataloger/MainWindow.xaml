<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WinUI_Cataloger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI_Cataloger"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WinUI Cataloger">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*">
        <Grid.Resources>
            <!-- Grouped CollectionViewSource — bound in code-behind -->
            <CollectionViewSource x:Name="GroupedAppsSource" IsSourceGrouped="True" />
        </Grid.Resources>
        <!-- Custom TitleBar -->
        <TitleBar x:Name="AppTitleBar" Grid.Row="0" Title="WinUI Cataloger" Subtitle="Visual App Manager">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <!-- NavigationView -->
        <NavigationView x:Name="MainNav" Grid.Row="1" IsBackButtonVisible="Collapsed" PaneDisplayMode="Top" IsSettingsVisible="True" SelectionChanged="MainNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeItem" Content="Home" Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="EditItem" Content="Batch Edit" Tag="Edit">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE70F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            
            <!-- Main Content Area Frame to swap pages -->
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
