<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUI_Cataloger.Views.AddAppControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI_Cataloger.Views"
    xmlns:models="using:WinUI_Cataloger.Models"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="4" HorizontalAlignment="Stretch">
        <!-- App Source Card -->
        <labs:SettingsCard Header="App Source URL" 
                           Description="Provide the GitHub repository or Microsoft Store page link">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE71B;"/>
            </labs:SettingsCard.HeaderIcon>
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Width="320">
                <TextBox x:Name="UrlInput"
                         PlaceholderText="https://github.com/..."
                         TextChanged="UrlInput_TextChanged"
                         VerticalAlignment="Center"/>
                <Button x:Name="FetchButton" Content="Fetch"
                        Click="FetchButton_Click"
                        Style="{ThemeResource AccentButtonStyle}"
                        Grid.Column="1" VerticalAlignment="Center"/>
                <FontIcon x:Name="FetchSuccessIcon" Glyph="&#xE8FB;"
                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                          Grid.Column="2" VerticalAlignment="Center"
                          Visibility="Collapsed" Margin="4,0,0,0"/>
            </Grid>
        </labs:SettingsCard>

        <!-- Status Info Bar inline under Source -->
        <InfoBar x:Name="StatusInfo" IsOpen="False" Severity="Informational" IsClosable="True" Margin="0,0,0,4" />

        <!-- App Identity Card -->
        <labs:SettingsCard Header="App Name"
                           Description="The display name of the application">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE104;"/>
            </labs:SettingsCard.HeaderIcon>
            <TextBox x:Name="NameInput"
                     PlaceholderText="e.g. Files"
                     Width="320"
                     TextChanged="Input_TextChanged"
                     VerticalAlignment="Center"/>
        </labs:SettingsCard>

        <!-- Category Picker Card -->
        <labs:SettingsCard Header="Category"
                           Description="Select the catalog category for this app">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE81E;"/>
            </labs:SettingsCard.HeaderIcon>
            <Button x:Name="CategoryButton"
                    Width="320"
                    HorizontalContentAlignment="Left">
                <Button.Flyout>
                    <Flyout x:Name="CategoryFlyout" Placement="Bottom">
                        <Grid RowDefinitions="Auto,*" RowSpacing="12" Width="300" Height="500">
                            <TextBox Grid.Row="0" x:Name="CategorySearchBox" PlaceholderText="Search categories..." TextChanging="CategorySearchBox_TextChanging" Header="" Margin="0,4,0,4"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <TreeView x:Name="CategoryTree"
                                          SelectionMode="Single"
                                          ItemInvoked="CategoryTree_ItemInvoked">
                                    <TreeView.ItemTemplate>
                                        <DataTemplate x:DataType="models:CategoryNode">
                                            <TreeViewItem ItemsSource="{x:Bind Children}"
                                                          IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                          AutomationProperties.Name="{x:Bind Name}">
                                                <TreeViewItem.Content>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                        <Image Width="16" Height="16" VerticalAlignment="Center"
                                                               Visibility="{x:Bind IconVisibility}">
                                                            <Image.Source>
                                                                <SvgImageSource UriSource="{x:Bind IconUri}"
                                                                                RasterizePixelWidth="16" RasterizePixelHeight="16"/>
                                                            </Image.Source>
                                                        </Image>
                                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </TreeViewItem.Content>
                                            </TreeViewItem>
                                        </DataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </ScrollViewer>
                        </Grid>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="CategoryButtonText" Text="Select a category..." />
                </StackPanel>
            </Button>
        </labs:SettingsCard>

        <!-- Logo URL Card -->
        <labs:SettingsCard Header="Logo Image Link"
                           Description="Provide an online logo or raw repository image path">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE723;"/>
            </labs:SettingsCard.HeaderIcon>
            <StackPanel Spacing="4" Width="320" VerticalAlignment="Center">
                <TextBox x:Name="LogoUrlInput"
                         PlaceholderText="https://raw.githubusercontent.com/..."
                         TextChanged="LogoUrlInput_TextChanged"/>
                <HyperlinkButton x:Name="LogoSuggestionLink" Visibility="Collapsed"
                                 Click="LogoSuggestionLink_Click" Padding="0">
                    <TextBlock x:Name="LogoSuggestionText" TextWrapping="Wrap"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemAccentColor}" />
                </HyperlinkButton>
            </StackPanel>
        </labs:SettingsCard>

        <!-- Design Indicator Card -->
        <labs:SettingsCard Header="Design Language"
                           Description="Which styling properties does this app target?">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE7B5;"/>
            </labs:SettingsCard.HeaderIcon>
            <labs:Segmented x:Name="IndicatorSegment" SelectedIndex="0"
                            SelectionChanged="Input_TextChanged"
                            Width="320" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch">
                <labs:SegmentedItem Content="WD" Tag="WD" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="WDM" Tag="WDM" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="WDA" Tag="WDA" HorizontalAlignment="Stretch" />
            </labs:Segmented>
        </labs:SettingsCard>

        <!-- Pricing Card -->
        <labs:SettingsCard Header="Pricing"
                           Description="Select FOSS or Paid options">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE10A;"/>
            </labs:SettingsCard.HeaderIcon>
            <labs:Segmented x:Name="PricingSegment" 
                            Width="320" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="0"
                            SelectionChanged="PricingSegment_SelectionChanged">
                <labs:SegmentedItem Content="Free" Tag="Free" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="FOSS" Tag="FOSS" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="Paid" Tag="Paid" HorizontalAlignment="Stretch" />
            </labs:Segmented>
        </labs:SettingsCard>

        <!-- Project State Card -->
        <labs:SettingsCard Header="Project State"
                           Description="Mark app developmental progress or status">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE737;"/>
            </labs:SettingsCard.HeaderIcon>
            <labs:Segmented x:Name="ProjectStateSegment" 
                            Width="320" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="0"
                            SelectionChanged="ProjectStateSegment_SelectionChanged">
                <labs:SegmentedItem Content="Active" Tag="Active" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="Planned" Tag="Planned" HorizontalAlignment="Stretch" />
                <labs:SegmentedItem Content="Discontinued" Tag="Discontinued" HorizontalAlignment="Stretch" />
            </labs:Segmented>
        </labs:SettingsCard>

        <!-- Preview Block -->
        <labs:SettingsCard Header="Markdown Line Preview" 
                           Description="Line format added to target README section">
            <labs:SettingsCard.HeaderIcon>
                <FontIcon Glyph="&#xE90A;"/>
            </labs:SettingsCard.HeaderIcon>
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="8,6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Width="320">
                <TextBlock x:Name="PreviewText" TextWrapping="Wrap"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </labs:SettingsCard>
    </StackPanel>
</UserControl>
