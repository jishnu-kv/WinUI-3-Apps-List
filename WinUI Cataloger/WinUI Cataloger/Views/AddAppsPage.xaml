<Page
    x:Class="WinUI_Cataloger.Views.AddAppsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUI_Cataloger.Views"
    xmlns:models="using:WinUI_Cataloger.Models"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    Background="Transparent"
    NavigationCacheMode="Required">

    <Page.Resources>
        <!-- Grouped CollectionViewSource for Visual Preview -->
        <CollectionViewSource x:Name="GroupedAppsSource" IsSourceGrouped="True" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="24">
            <!-- Row 0: 2-column layout: Form on the left (3*), Queue on the right (2*) -->
            <Grid Grid.Row="0" ColumnDefinitions="3*,2*" ColumnSpacing="24">
                <!-- Left Column: App Entry Form -->
                <StackPanel Grid.Column="0" Spacing="16">
                    <TextBlock Text="New App Information" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <local:AddAppControl x:Name="AppForm" />
                    <Button x:Name="QueueAppButton" Content="Add App to Batch Queue" Click="QueueAppButton_Click" HorizontalAlignment="Stretch" Style="{ThemeResource DefaultButtonStyle}" Padding="12,8" />
                </StackPanel>

                <!-- Right Column: Queue list rendered directly in UI -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="12">
                    <TextBlock Grid.Row="0" Text="Current Queue" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ListView Grid.Row="1" x:Name="QueueListView" SelectionMode="None" Background="Transparent">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FlatAppItem">
                                <!-- Direct UI Card: Border with custom styling -->
                                <Border CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <!-- Logo -->
                                        <Image Grid.Column="0" Source="{x:Bind DisplayLogoUrl}" Width="36" Height="36" Stretch="Uniform" VerticalAlignment="Center" />
                                        
                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Url}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                <TextBlock Text="{x:Bind GroupKey}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <Border CornerRadius="4" Padding="4,1" Background="{ThemeResource SystemFillColorSuccessBrush}">
                                                    <TextBlock Text="{x:Bind Indicator}" FontSize="8" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <Button Click="EditQueueItem_Click" Style="{ThemeResource SubtleButtonStyle}" Padding="4">
                                                <FontIcon Glyph="&#xE70F;" FontSize="12" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                                            </Button>
                                            <Button Click="RemoveFromQueue_Click" Style="{ThemeResource SubtleButtonStyle}" Padding="4">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Queue Empty State -->
                    <StackPanel Grid.Row="1" x:Name="QueueEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Margin="0,24,0,24" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8B9;" FontSize="36" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Queue is empty" Style="{ThemeResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Fill out the form on the left to add apps." FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Row 1: Divider -->
            <MenuFlyoutSeparator Grid.Row="1" />

            <!-- Row 2: Visual Preview section (moved from preview page) -->
            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock Grid.Row="0" Text="Visual Categories Preview (With Queued Items)" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <GridView Grid.Row="1"
                          x:Name="AppsGridView"
                          Padding="0"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ItemsSource="{Binding Source={StaticResource GroupedAppsSource}}"
                          SizeChanged="AppsGridView_SizeChanged">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid AreStickyGroupHeadersEnabled="False" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:FlatAppItem">
                            <!-- Vertical Card matching Homepage -->
                            <Border CornerRadius="6"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                                    BorderThickness="1"
                                    Margin="6"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    PointerEntered="Card_PointerEntered"
                                    PointerExited="Card_PointerExited">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                                <Grid RowDefinitions="*,Auto" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <!-- Top: Logo Container (Swaps between Image and Letter Fallback) -->
                                    <Grid Grid.Row="0" Height="90" Background="Transparent" Padding="12">
                                        <Image Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Source="{x:Bind DisplayLogoUrl}" Stretch="Uniform"
                                               Visibility="{x:Bind HasLogoVisibility}"/>
                                        <Border Width="48" Height="48" CornerRadius="8"
                                                Background="{x:Bind FallbackBackgroundBrush}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Visibility="{x:Bind FallbackVisibility}">
                                            <TextBlock Text="{x:Bind FirstLetter}"
                                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Width="10" Height="10" CornerRadius="5" Margin="4"
                                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Visibility="{x:Bind IsNewVisibility}"/>
                                    </Grid>
                                    
                                    <!-- Bottom: Details Container with Darker Background -->
                                    <Border Grid.Row="1" 
                                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" 
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="8,8,8,8">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                                            <TextBlock Grid.Row="0" Text="{x:Bind Name}"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                       HorizontalAlignment="Left"
                                                       MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Row="1" Text="{x:Bind Url}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Left"
                                                       MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left" Margin="0,2,0,0">
                                                <TextBlock Text="{x:Bind Indicator}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Border CornerRadius="8" Height="16" Padding="8,0"
                                                        Background="{x:Bind PaymentBadgeBackground}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind PaymentBadgeText}"
                                                               Foreground="{x:Bind PaymentBadgeForeground}"
                                                               FontSize="9" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderContainerStyle>
                                <Style TargetType="GridViewHeaderItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GridViewHeaderItem">
                                                <ContentPresenter
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.HeaderContainerStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate x:DataType="models:AppGroup">
                                    <StackPanel Orientation="Horizontal" Spacing="10"
                                                Margin="0,16,0,6" VerticalAlignment="Center">
                                        <Image Width="22" Height="22" VerticalAlignment="Center"
                                               Visibility="{x:Bind IconVisibility}">
                                            <Image.Source>
                                                <SvgImageSource UriSource="{x:Bind IconUri}"
                                                                RasterizePixelWidth="22" RasterizePixelHeight="22"/>
                                            </Image.Source>
                                        </Image>
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </GridView.GroupStyle>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                </GridView>

                <!-- Preview Empty State -->
                <StackPanel Grid.Row="1" x:Name="PreviewEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Margin="0,48,0,48" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE7B3;" FontSize="36" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="No preview available" Style="{ThemeResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Add apps to the batch queue to preview their categories." FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
